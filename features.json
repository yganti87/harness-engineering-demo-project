      "id": "F001",
      "name": "Anonymous Book Search",
      "status": "completed",
      "priority": "high",
      "description": "Users can search the library catalog by title, author, ISBN, or genre without requiring authentication.",
      "acceptanceCriteria": [
        "GET /api/v1/books/search returns paginated list of books",
        "Searching by keyword (q param) matches title, author, or ISBN (case-insensitive)",
        "Filtering by genre returns only books of that genre",
        "Empty search returns all books sorted by title",
        "Response is wrapped in standard ApiResponse envelope",
        "Pagination works correctly (page, size, totalPages, totalElements)",
        "Streamlit UI shows search bar + genre dropdown + paginated results grid",
        "Each book card shows title, author, genre, year, description preview"
      ],
      "testSteps": [
        "Unit: BookServiceTest.searchBooks_withKeyword_returnsMatchingBooks",
        "Unit: BookServiceTest.searchBooks_withGenre_returnsFilteredBooks",
        "Unit: BookServiceTest.searchBooks_empty_returnsAllBooks",
        "Integration: BookSearchIntegrationTest.search_withKeyword_returns200WithResults",
        "Integration: BookSearchIntegrationTest.search_withGenre_returnsFilteredResults",
        "Integration: BookSearchIntegrationTest.search_emptyQuery_returnsAllBooksPaginated",
        "Architecture: LayerDependencyTest.controller_shouldNotDependOnRepository"
      ],
