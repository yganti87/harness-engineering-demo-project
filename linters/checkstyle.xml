<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  Checkstyle configuration for library-backend.
  Based on Google Java Style Guide with project-specific adjustments.

  Key differences from Google defaults:
  - Max line length: 120 (Google uses 100)
  - Javadoc required on public methods (warning level, not error)

  Error messages are written as remediation instructions for coding agents.
  Reference: docs/CODING_STYLE.md

  Usage (from backend/ directory):
    mvn checkstyle:check
  Bound to validate phase automatically by pom.xml.
-->
<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java"/>

    <!-- Exclude module-info.java -->
    <module name="BeforeExecutionExclusionFileFilter">
        <property name="fileNamePattern" value="module\-info\.java$"/>
    </module>
    <!-- Exclude LibraryApplication (Spring Boot needs visible constructor; HideUtilityClassConstructor false positive) -->
    <module name="BeforeExecutionExclusionFileFilter">
        <property name="fileNamePattern" value="LibraryApplication\.java$"/>
    </module>

    <!-- ── File-level checks ─────────────────────────────────────────── -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
        <message key="containsTab"
            value="Line contains a tab character. Use 4 spaces for indentation. FIX: Configure your editor to expand tabs. See docs/CODING_STYLE.md"/>
    </module>

    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
        <message key="maxLineLength"
            value="Line length {0,number,integer} exceeds maximum {1,number,integer}. FIX: Break the method chain across lines or extract a variable. See docs/CODING_STYLE.md"/>
    </module>

    <module name="NewlineAtEndOfFile">
        <message key="noNewlineAtEOF"
            value="File does not end with a newline. FIX: Add a blank line at the end of the file."/>
    </module>

    <module name="TreeWalker">

        <!-- ── Imports ──────────────────────────────────────────────── -->
        <module name="AvoidStarImport">
            <message key="import.avoidStar"
                value="Wildcard import ''{0}'' is not allowed. FIX: Replace with explicit imports for each class used. See docs/CODING_STYLE.md"/>
        </module>
        <module name="UnusedImports">
            <message key="import.unused"
                value="Unused import ''{0}''. FIX: Remove this import. Run: mvn checkstyle:check after removal."/>
        </module>
        <module name="IllegalImport">
            <property name="illegalPkgs" value="sun"/>
        </module>
        <module name="RedundantImport">
            <message key="import.duplicate"
                value="Duplicate import ''{1}''. FIX: Remove the duplicate import line."/>
        </module>

        <!-- ── Naming ────────────────────────────────────────────────── -->
        <module name="TypeName">
            <message key="name.invalidPattern"
                value="Type name ''{0}'' does not match pattern ''{1}''. FIX: Use UpperCamelCase for class and interface names. See docs/CODING_STYLE.md"/>
        </module>
        <module name="MemberName">
            <message key="name.invalidPattern"
                value="Member name ''{0}'' does not match pattern ''{1}''. FIX: Use lowerCamelCase for field names. See docs/CODING_STYLE.md"/>
        </module>
        <module name="MethodName">
            <message key="name.invalidPattern"
                value="Method name ''{0}'' does not match pattern ''{1}''. FIX: Use lowerCamelCase for method names. See docs/CODING_STYLE.md"/>
        </module>
        <module name="ParameterName">
            <message key="name.invalidPattern"
                value="Parameter name ''{0}'' does not match pattern ''{1}''. FIX: Use lowerCamelCase for parameter names."/>
        </module>
        <module name="LocalVariableName">
            <message key="name.invalidPattern"
                value="Local variable name ''{0}'' does not match pattern ''{1}''. FIX: Use lowerCamelCase for local variables."/>
        </module>
        <module name="ConstantName">
            <message key="name.invalidPattern"
                value="Constant name ''{0}'' does not match pattern ''{1}''. FIX: Use UPPER_SNAKE_CASE for constants (static final fields). See docs/CODING_STYLE.md"/>
        </module>
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
            <message key="name.invalidPattern"
                value="Package name ''{0}'' must be all lowercase with dots. FIX: Use lowercase letters only in package names."/>
        </module>

        <!-- ── Braces ────────────────────────────────────────────────── -->
        <module name="NeedBraces">
            <message key="needBraces"
                value="''{0}'' construct must use curly braces. FIX: Add ''{}'' even for single-line blocks. See docs/CODING_STYLE.md"/>
        </module>
        <module name="LeftCurly"/>
        <module name="RightCurly"/>

        <!-- ── Whitespace ─────────────────────────────────────────────── -->
        <module name="WhitespaceAround">
            <property name="allowEmptyConstructors" value="true"/>
            <property name="allowEmptyMethods" value="true"/>
            <property name="allowEmptyTypes" value="true"/>
            <property name="allowEmptyLambdas" value="true"/>
        </module>
        <module name="WhitespaceAfter"/>
        <module name="NoWhitespaceBefore"/>
        <module name="GenericWhitespace"/>
        <module name="EmptyLineSeparator">
            <property name="allowNoEmptyLineBetweenFields" value="true"/>
            <property name="allowMultipleEmptyLines" value="false"/>
        </module>
        <module name="SingleSpaceSeparator"/>

        <!-- ── Modifiers ─────────────────────────────────────────────── -->
        <module name="ModifierOrder">
            <message key="mod.order"
                value="''{0}'' modifier out of order. FIX: Use order: public/protected/private static abstract default final transient volatile synchronized native strictfp. See docs/CODING_STYLE.md"/>
        </module>
        <module name="RedundantModifier"/>

        <!-- ── Code style ─────────────────────────────────────────────── -->
        <module name="OneStatementPerLine">
            <message key="multiple.statements.line"
                value="Multiple statements on same line. FIX: Put each statement on its own line. See docs/CODING_STYLE.md"/>
        </module>
        <module name="MultipleVariableDeclarations">
            <message key="multiple.variable.declarations"
                value="Multiple variable declarations on same line. FIX: Declare each variable on its own line."/>
        </module>
        <module name="FallThrough">
            <message key="fall.through"
                value="Fall-through from previous case without comment. FIX: Add a '// falls through' comment or a break statement."/>
        </module>
        <module name="MissingSwitchDefault">
            <message key="missing.switch.default"
                value="Switch statement does not have a default clause. FIX: Add a default case. See docs/CODING_STYLE.md"/>
        </module>

        <!-- ── Class design ───────────────────────────────────────────── -->
        <module name="InterfaceIsType">
            <message key="interface.type"
                value="Interface ''{0}'' does not define any methods. FIX: Marker interfaces should be replaced with annotations."/>
        </module>
        <module name="HideUtilityClassConstructor">
            <message key="hide.utility.class"
                value="Utility class has public constructor. FIX: Add a private no-arg constructor to prevent instantiation."/>
        </module>

        <!-- ── Empty blocks ───────────────────────────────────────────── -->
        <module name="EmptyBlock">
            <property name="option" value="TEXT"/>
            <message key="block.empty"
                value="Empty {0} block. FIX: Add a comment explaining why it is intentionally empty, e.g., // intentionally empty"/>
        </module>
        <module name="EmptyCatchBlock">
            <property name="exceptionVariableName" value="expected|ignored"/>
            <message key="catch.block.empty"
                value="Empty catch block. FIX: Handle the exception or add a comment explaining why it is safe to ignore. Name the variable ''ignored'' if intentional."/>
        </module>

        <!-- ── Quality ────────────────────────────────────────────────── -->
        <module name="EqualsHashCode">
            <message key="equals.noHashCode"
                value="Class defines equals() but not hashCode(). FIX: Always override both equals() and hashCode() together. See docs/COMMON_PITFALLS.md P008."/>
        </module>

        <!-- ── Annotations ────────────────────────────────────────────── -->
        <module name="AnnotationLocation">
            <property name="allowSamelineSingleParameterlessAnnotation" value="false"/>
            <message key="annotation.location.alone"
                value="Annotation ''{0}'' should be on its own line. FIX: Move each annotation to its own line above the declaration."/>
        </module>

    </module>
</module>
