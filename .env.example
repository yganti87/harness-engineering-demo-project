# Library App Environment Variables
# Copy this file to .env and adjust values for your environment
# .env is gitignored — never commit secrets

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=library_db
POSTGRES_USER=library_user
POSTGRES_PASSWORD=library_pass

# ─── Backend (Spring Boot) ────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=docker
# Used by backend container to connect to DB (Docker DNS name: db)
DB_HOST=db
DB_PORT=5432
DB_NAME=library_db
DB_USER=library_user
DB_PASSWORD=library_pass
# Log level: INFO (production), DEBUG (development)
LOG_LEVEL=INFO

# ─── Frontend (Streamlit) ─────────────────────────────────────────────────────
# Docker DNS name for backend (used inside Docker network)
BACKEND_URL=http://backend:8080

# ─── Ports (host-side) ────────────────────────────────────────────────────────
BACKEND_PORT=8080
FRONTEND_PORT=8501
DB_HOST_PORT=5433

# ─── GitHub CLI (optional, for AI agents / automation) ─────────────────────────
# Required when gh runs non-interactively (e.g. Cursor agent). Create at:
# https://github.com/settings/tokens/new (scope: repo)
# GH_TOKEN=ghp_xxxxxxxxxxxx
