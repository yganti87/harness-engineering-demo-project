<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  Backend checkstyle configuration — delegates to linters/checkstyle.xml.
  This file is needed because maven-checkstyle-plugin resolves configLocation
  relative to the backend/ directory.

  To keep rules in sync: edit ../linters/checkstyle.xml (the source of truth),
  then copy its content here.

  See docs/CODING_STYLE.md for style guide.
-->

<!-- This is a copy of ../linters/checkstyle.xml. Keep in sync. -->
<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java"/>

    <module name="BeforeExecutionExclusionFileFilter">
        <property name="fileNamePattern" value="module\-info\.java$"/>
    </module>
    <module name="BeforeExecutionExclusionFileFilter">
        <property name="fileNamePattern" value="LibraryApplication\.java$"/>
    </module>

    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
        <message key="containsTab"
            value="Line contains a tab character. Use 4 spaces for indentation. FIX: Configure your editor to expand tabs. See docs/CODING_STYLE.md"/>
    </module>

    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
        <message key="maxLineLength"
            value="Line length {0,number,integer} exceeds maximum {1,number,integer}. FIX: Break the method chain across lines or extract a variable. See docs/CODING_STYLE.md"/>
    </module>

    <module name="NewlineAtEndOfFile">
        <message key="noNewlineAtEOF"
            value="File does not end with a newline. FIX: Add a blank line at the end of the file."/>
    </module>

    <module name="TreeWalker">

        <module name="AvoidStarImport">
            <message key="import.avoidStar"
                value="Wildcard import ''{0}'' is not allowed. FIX: Replace with explicit imports. See docs/CODING_STYLE.md"/>
        </module>
        <module name="UnusedImports">
            <message key="import.unused"
                value="Unused import ''{0}''. FIX: Remove this import."/>
        </module>
        <module name="IllegalImport">
            <property name="illegalPkgs" value="sun"/>
        </module>
        <module name="RedundantImport"/>

        <module name="TypeName">
            <message key="name.invalidPattern"
                value="Type name ''{0}'' must be UpperCamelCase. FIX: Rename to UpperCamelCase. See docs/CODING_STYLE.md"/>
        </module>
        <module name="MemberName">
            <message key="name.invalidPattern"
                value="Member name ''{0}'' must be lowerCamelCase. FIX: Rename to lowerCamelCase. See docs/CODING_STYLE.md"/>
        </module>
        <module name="MethodName"/>
        <module name="ParameterName"/>
        <module name="LocalVariableName"/>
        <module name="ConstantName">
            <message key="name.invalidPattern"
                value="Constant ''{0}'' must be UPPER_SNAKE_CASE. FIX: Rename to UPPER_SNAKE_CASE. See docs/CODING_STYLE.md"/>
        </module>
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
        </module>

        <module name="NeedBraces">
            <message key="needBraces"
                value="''{0}'' construct must use curly braces. FIX: Add braces even for single-line blocks. See docs/CODING_STYLE.md"/>
        </module>
        <module name="LeftCurly"/>
        <module name="RightCurly"/>

        <module name="WhitespaceAround">
            <property name="allowEmptyConstructors" value="true"/>
            <property name="allowEmptyMethods" value="true"/>
            <property name="allowEmptyTypes" value="true"/>
            <property name="allowEmptyLambdas" value="true"/>
        </module>
        <module name="WhitespaceAfter"/>
        <module name="NoWhitespaceBefore"/>
        <module name="GenericWhitespace"/>
        <module name="EmptyLineSeparator">
            <property name="allowNoEmptyLineBetweenFields" value="true"/>
            <property name="allowMultipleEmptyLines" value="false"/>
        </module>
        <module name="SingleSpaceSeparator"/>

        <module name="ModifierOrder"/>
        <module name="RedundantModifier"/>

        <module name="OneStatementPerLine"/>
        <module name="MultipleVariableDeclarations"/>
        <module name="FallThrough"/>
        <module name="MissingSwitchDefault"/>

        <module name="InterfaceIsType"/>
        <module name="HideUtilityClassConstructor"/>

        <module name="EmptyBlock">
            <property name="option" value="TEXT"/>
        </module>
        <module name="EmptyCatchBlock">
            <property name="exceptionVariableName" value="expected|ignored"/>
        </module>

        <module name="EqualsHashCode">
            <message key="equals.noHashCode"
                value="Class defines equals() but not hashCode(). FIX: Always override both. See docs/COMMON_PITFALLS.md P008."/>
        </module>

        <module name="AnnotationLocation">
            <property name="allowSamelineSingleParameterlessAnnotation" value="false"/>
        </module>

    </module>
</module>
